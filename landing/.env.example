# Supabase (přihlášení)
PUBLIC_SUPABASE_URL=https://xxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL aplikace (kam přesměrovat po přihlášení)
PUBLIC_APP_URL=https://tvoje-app.vercel.app/app

# URL Flask API (pouze pro produkci – když API běží jinde než proxy)
# V dev se používá proxy na localhost:5000
PUBLIC_API_URL=

